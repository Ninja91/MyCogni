{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_version", "milestone_attestations", "packages"],
  "properties": {
    "schema_version": {"const": 1},
    "registry_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "milestone_attestations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "milestone", "packages", "dependency_packages", "gates", "gate_evidence_ids", "reviewed_commit", "review_record", "disposition"],
        "properties": {
          "id": {"type": "string", "pattern": "^MATT-[A-Z0-9-]+$"},
          "milestone": {"enum": ["M0", "M1", "M2", "M3", "M4", "M5", "M6"]},
          "packages": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "dependency_packages": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "gates": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "gate_evidence_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "reviewed_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "review_record": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": {"type": "string"},
              "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }
          },
          "disposition": {"const": "ACCEPT"}
        }
      }
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "evidence_ids"],
        "properties": {
          "id": {"type": "string"},
          "status": {"enum": ["NOT_STARTED", "IN_PROGRESS", "BLOCKED", "COMPLETE", "VERIFIED"]},
          "evidence_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
        }
      }
    }
  }
}
