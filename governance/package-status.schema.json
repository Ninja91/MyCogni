{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_version", "milestone_definitions", "milestone_attestations", "packages"],
  "properties": {
    "schema_version": {"const": 2},
    "registry_version": {"type": "string", "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$"},
    "milestone_definitions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "milestone", "packages", "gates"],
        "properties": {
          "id": {"type": "string", "pattern": "^MDEF-M[0-6]$"},
          "milestone": {"enum": ["M0", "M1", "M2", "M3", "M4", "M5", "M6"]},
          "packages": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "gates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "evidence_ids"],
              "properties": {
                "id": {"type": "string", "pattern": "^[A-Z0-9]+(?:-[A-Z0-9]+)*$"},
                "evidence_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
              }
            }
          }
        }
      }
    },
    "milestone_attestations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "definition_id", "packages", "package_attestation_ids", "gates", "reviewer", "reviewed_commit", "review_record", "disposition", "findings", "residuals"],
        "properties": {
          "id": {"type": "string", "pattern": "^MATT-[A-Z0-9-]+$"},
          "definition_id": {"type": "string", "pattern": "^MDEF-M[0-6]$"},
          "packages": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "package_attestation_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "gates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "evidence_ids"],
              "properties": {
                "id": {"type": "string"},
                "evidence_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
              }
            }
          },
          "reviewer": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "role"],
            "properties": {
              "id": {"type": "string"},
              "role": {"enum": ["INDEPENDENT_ADVERSARIAL_REVIEWER", "INDEPENDENT_PRIVACY_REVIEWER", "INDEPENDENT_SECURITY_REVIEWER"]}
            }
          },
          "reviewed_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "review_record": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": {"type": "string"},
              "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }
          },
          "disposition": {"const": "ACCEPT"},
          "findings": {"type": "array", "items": {"type": "string"}},
          "residuals": {"type": "array", "minItems": 1, "items": {"type": "string"}}
        }
      }
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "evidence_ids"],
        "properties": {
          "id": {"type": "string"},
          "status": {"enum": ["NOT_STARTED", "IN_PROGRESS", "BLOCKED", "COMPLETE", "VERIFIED"]},
          "evidence_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
        }
      }
    }
  }
}
