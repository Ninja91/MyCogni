{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycogni.example/schemas/broker-connector-manifest-v1.json",
  "title": "MyCogni broker connector manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "connector_id",
    "version",
    "broker",
    "destinations",
    "capabilities",
    "provenance",
    "review"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "connector_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "broker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "category", "jurisdictions"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "name": {"type": "string", "minLength": 1},
        "category": {"enum": ["people_search", "marketing", "risk", "recruitment", "other"]},
        "jurisdictions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "destinations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["origin", "purpose"],
        "properties": {
          "origin": {"type": "string", "format": "uri", "pattern": "^https://"},
          "purpose": {"enum": ["observe", "submit", "poll", "verify"]},
          "allow_subdomains": {"type": "boolean", "default": false}
        }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "transport", "identity_attributes", "automation", "rate_limit"],
        "properties": {
          "name": {"enum": ["observe", "prepare", "submit", "poll", "verify"]},
          "transport": {"enum": ["http", "email", "browser", "protocol", "guided_manual"]},
          "identity_attributes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "requirement", "reason"],
              "properties": {
                "type": {"enum": ["name", "alias", "email", "phone", "address", "date_of_birth", "broker_record_id", "authorization_document", "identity_document"]},
                "requirement": {"enum": ["required", "optional", "conditional"]},
                "reason": {"type": "string", "minLength": 1}
              }
            }
          },
          "automation": {"enum": ["observe_only", "approval_required", "eligible_for_pre_authorization", "guided_manual"]},
          "rate_limit": {
            "type": "object",
            "additionalProperties": false,
            "required": ["max_actions", "period_seconds"],
            "properties": {
              "max_actions": {"type": "integer", "minimum": 1},
              "period_seconds": {"type": "integer", "minimum": 1}
            }
          },
          "limitations": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url", "observed_at", "kind"],
        "properties": {
          "url": {"type": "string", "format": "uri"},
          "observed_at": {"type": "string", "format": "date-time"},
          "kind": {"enum": ["broker_privacy_page", "government_registry", "terms", "manual_observation", "other"]}
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewed_at", "expires_at", "reviewers"],
      "properties": {
        "status": {"enum": ["proposed", "observe_sandbox", "canary", "approval_gated", "trusted", "quarantined", "retired"]},
        "reviewed_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"},
        "reviewers": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    }
  }
}
