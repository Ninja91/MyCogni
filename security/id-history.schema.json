{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycogni.example/schemas/id-history-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "history_version", "allocations"],
  "properties": {
    "schema_version": {"const": 1},
    "history_version": {"type": "string", "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$"},
    "allocations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "identity", "state", "introduced_in"],
        "properties": {
          "id": {"type": "string"},
          "kind": {"enum": ["THREAT", "VERIFICATION_TEST"]},
          "identity": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "state": {"enum": ["ACTIVE", "RETIRED"]},
          "introduced_in": {"type": "string", "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$"}
        }
      }
    }
  }
}
